				<key>script</key>
				<string>function run(argv) {
  const q = (argv[0] || "").trim();
  const base = "https://github.com";
  if (!q) {
    return JSON.stringify({ items: [{
      title: "Type to search GitHub",
      subtitle: "e.g. gh alfredapp/alfred  ·  gh streaming json",
      valid: false
    }] });
  }
  const enc = encodeURIComponent(q);
  const items = [];
  // owner/repo → offer to open it directly (live preview of the resolved URL)
  if (/^[\w.-]+\/[\w.-]+$/.test(q)) {
    const url = `${base}/${q}`;
    items.push({
      uid: "open", title: `Open ${q}`, subtitle: url, arg: url,
      icon: { path: "icon.png" },
      mods: { cmd: { subtitle: "Copy link", arg: url } }
    });
  }
  for (const [kind, type] of [["repositories", "repositories"], ["code", "code"], ["issues", "issues"]]) {
    const url = `${base}/search?q=${enc}&amp;type=${type}`;
    items.push({ uid: kind, title: `Search ${kind} for "${q}"`, subtitle: url, arg: url,
                 mods: { cmd: { subtitle: "Copy link", arg: url } } });
  }
  return JSON.stringify({ items });
}</string>
